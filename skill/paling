#!/usr/bin/env bash
# paling: thin wrapper over the paling daemon API. every bento operation is an
# API call -- nothing here hand-places files. this is the wrapper delightd
# surfaces as the agent skill; an agent (or a human) drives paling through it
# instead of mucking in the shell/filesystem.
set -euo pipefail

base="${PALING_API:-http://localhost:8090}"

usage() {
  cat >&2 <<'EOF'
usage:
  paling create-bento [name] [archetype]   create a bento (uuid name if omitted)
  paling ingest <bento> <source_path>      ingest a markdown corpus into a bento
  paling verify <bento>                     check a bento is processable (preflight)
  paling profile <bento>                    profile the corpus -> taxonometry metrics
  paling extract <bento>                    extract the relationship graph
  paling questions <bento>                  generate questions (stage 4, convergence)
  paling answers <bento>                    generate answers for stage-4 questions (stage 5)
  paling curate <bento>                     grade answers w/ the summarization model (stage 6)
  paling dataset <bento>                    build train/valid jsonl from approved pairs (stage 7)
  paling prepare <bento>                    enqueue dataset preparation
  paling train <bento>                      enqueue training
  paling status <bento>                     report bento state
EOF
  exit 2
}

cmd="${1:-}"; shift || true
case "$cmd" in
  create-bento)
    body="{}"
    [ $# -ge 1 ] && body="{\"name\":\"$1\"${2:+,\"archetype\":\"$2\"}}"
    curl -fsS -X POST "$base/bento" -H 'content-type: application/json' -d "$body"
    ;;
  ingest)
    [ $# -eq 2 ] || usage
    curl -fsS -X POST "$base/bento/$1/corpus" -H 'content-type: application/json' \
      -d "{\"source_path\":\"$2\"}"
    ;;
  verify)    [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/verify" ;;
  profile)   [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/profile" ;;
  extract)   [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/extract" ;;
  questions) [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/questions" ;;
  answers)   [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/answers" ;;
  curate)    [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/curate" ;;
  dataset)   [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/dataset" ;;
  prepare)   [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/prepare" ;;
  train)     [ $# -eq 1 ] || usage; curl -fsS -X POST "$base/bento/$1/train" ;;
  status)    [ $# -eq 1 ] || usage; curl -fsS "$base/bento/$1/status" ;;
  *) usage ;;
esac
echo
